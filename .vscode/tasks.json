{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "C: 현재 파일 컴파일 및 실행",
            "type": "shell",
            "command": "gcc \"${file}\" -o \"${fileDirname}\\${fileBasenameNoExtension}.exe\" && \"${fileDirname}\\${fileBasenameNoExtension}.exe\"",
            "group": { "kind": "build", "isDefault": true },
            "problemMatcher": ["$gcc"]
        }
    ]
}
